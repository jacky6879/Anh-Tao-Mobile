    "@tailwindcss/typography": "^0.5.19",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.4",
    "@vercel/analytics": "^1.4.1",
    "@vercel/speed-insights": "^1.1.0",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.469.0",
    "next": "16.2.3",

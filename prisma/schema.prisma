// ============================================================
// Anh Táo Mobile — Prisma schema
// Physical product catalog + repair services + bookings +
// trade-in requests + leads + reservations (orders) + referral.
// No digital download delivery (replaced by physical/reservation flow).
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== ENUMS =====
enum UserStatus {
  active
  blocked
}

enum ProductStatus {
  draft
  published
  archived
}

enum ProductCondition {
  new_seal
  like_new
  percent99
  used
  light_scratch
  repaired
  unknown
}

enum OrderStatus {
  pending
  paid
  cancelled
  refunded
  expired
  confirmed
}

enum OrderFulfillment {
  at_shop
  shipping
  hold
  consult
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum TradeInStatus {
  pending
  reviewed
  offered
  rejected
  completed
}

enum LeadType {
  buy
  hold
  repair
  tradein
  consult
}

enum LeadStatus {
  new
  contacted
  converted
  lost
}

enum ReviewStatus {
  pending
  published
  hidden
}

enum ReferralStatus {
  pending
  confirmed
  rejected
}

enum CouponType {
  percent
  fixed
}

enum AuditAction {
  create
  update
  delete
  confirm
  reject
  revoke
  admin_grant
  admin_revoke
  publish
  archive
}

// ===== AUTH (NextAuth standard) =====
model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  status        UserStatus @default(active)
  isAdmin       Boolean    @default(false)
  phone         String?
  referralCode  String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  accounts     Account[]
  sessions     Session[]
  orders       Order[]
  reviews      Review[]
  referrals    Referral[]    @relation("ReferrerReferrals")
  leads        Lead[]
  auditLogs    AuditLog[]
  couponUsages CouponUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== PRODUCT CATALOG =====
model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  icon        String?
  order       Int        @default(0)
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
  deletedAt   DateTime?

  @@index([parentId])
}

model Product {
  id               String           @id @default(cuid())
  slug             String           @unique
  title            String
  brand            String?
  model            String?
  storage          String?
  color            String?
  condition        ProductCondition @default(unknown)
  batteryHealth    Int?
  warranty         String?
  imeiStatus       String?
  origin           String?
  shortDescription String?
  longDescription  String?
  coverImage       String?
  gallery          String[]
  categoryId       String?
  category         Category?        @relation(fields: [categoryId], references: [id])
  tags             String[]
  status           ProductStatus    @default(draft)
  featured         Boolean          @default(false)
  price            Int
  comparePrice     Int?
  stock            Int              @default(0)
  salesCount       Int              @default(0)
  ratingAvg        Float?
  ratingCount      Int              @default(0)
  metaTitle        String?
  metaDescription  String?
  ogImage          String?
  installment      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  publishedAt      DateTime?
  deletedAt        DateTime?

  reviews    Review[]
  orderItems OrderItem[]

  @@index([status, featured, createdAt])
  @@index([categoryId, status])
  @@index([brand, condition])
}

// ===== REPAIR SERVICES =====
model RepairService {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  deviceBrand      String?
  deviceModel      String?
  serviceGroup     String
  serviceName      String?
  partType         String?
  partQuality      String?
  priceMin         Int
  priceMax         Int
  warranty         String?
  estimatedTime    String?
  shortDescription String?
  longDescription  String?
  coverImage       String?
  tags             String[]
  featured         Boolean       @default(false)
  status           ProductStatus @default(draft)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?
  deletedAt        DateTime?

  bookings RepairBooking[]

  @@index([status, featured])
  @@index([serviceGroup, status])
  @@index([deviceBrand])
}

// ===== ORDERS / RESERVATIONS =====
model Order {
  id           String           @id @default(cuid())
  publicCode   String           @unique
  userId       String?
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  buyerName    String
  buyerEmail   String
  buyerPhone   String
  buyerAddress String?
  fulfillment  OrderFulfillment @default(at_shop)
  subtotal     Int
  discount     Int              @default(0)
  total        Int
  status       OrderStatus      @default(pending)
  paymentMemo  String?
  paidAt       DateTime?
  paidBy       String?
  cancelledAt  DateTime?
  expiresAt    DateTime
  couponCode   String?
  referralCode String?
  ipAddress    String?
  userAgent    String?
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  items       OrderItem[]
  referral    Referral?
  couponUsage CouponUsage?

  @@index([userId, status, createdAt])
  @@index([status, expiresAt])
  @@index([buyerEmail])
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  productId        String
  productTitleSnap String
  priceSnap        Int
  qty              Int     @default(1)
  order            Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ===== REPAIR BOOKINGS =====
model RepairBooking {
  id             String         @id @default(cuid())
  publicCode     String         @unique
  serviceId      String?
  service        RepairService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  customerName   String
  customerPhone  String
  customerEmail  String?
  deviceBrand    String?
  deviceModel    String?
  fault          String
  desiredService String?
  scheduledAt    DateTime?
  note           String?
  imageUrl       String?
  status         BookingStatus  @default(pending)
  ipAddress      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([customerPhone])
}

// ===== TRADE-IN REQUESTS =====
model TradeInRequest {
  id            String        @id @default(cuid())
  publicCode    String        @unique
  customerName  String
  customerPhone String
  customerEmail String?
  currentDevice String
  storage       String?
  batteryHealth String?
  cosmetic      String?
  faults        String?
  wantedDevice  String?
  imageUrl      String?
  offeredPrice  Int?
  status        TradeInStatus @default(pending)
  note          String?
  ipAddress     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, createdAt])
}

// ===== LEADS =====
model Lead {
  id            String     @id @default(cuid())
  type          LeadType
  status        LeadStatus @default(new)
  customerName  String
  customerPhone String
  customerEmail String?
  message       String?
  productId     String?
  source        String?
  userId        String?
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status, createdAt])
  @@index([type])
}

// ===== COUPONS =====
model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  description    String?
  type           CouponType
  value          Int
  minOrderAmount Int?
  maxDiscount    Int?
  usageLimit     Int?
  usageCount     Int           @default(0)
  perUserLimit   Int?
  productIds     String[]
  startsAt       DateTime?
  expiresAt      DateTime?
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  usages         CouponUsage[]

  @@index([code, active])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  orderId   String   @unique
  userId    String?
  discount  Int
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([couponId, userId])
}

// ===== REVIEWS =====
model Review {
  id               String       @id @default(cuid())
  productId        String
  userId           String
  orderId          String?
  rating           Int
  title            String?
  body             String?
  verifiedPurchase Boolean      @default(false)
  status           ReviewStatus @default(pending)
  createdAt        DateTime     @default(now())
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId, status])
}

// ===== REFERRAL =====
model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  referralCode String
  orderId      String?        @unique
  buyerName    String
  buyerEmail   String?
  buyerPhone   String?
  amount       Int
  commission   Int
  status       ReferralStatus @default(pending)
  note         String?
  createdAt    DateTime       @default(now())
  confirmedAt  DateTime?
  confirmedBy  String?
  referrer     User           @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  order        Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([referrerId, status])
  @@index([status, createdAt])
}

// ===== MEDIA LIBRARY =====
model MediaAsset {
  id        String   @id @default(cuid())
  name      String
  url       String
  path      String
  mimeType  String
  sizeBytes BigInt
  alt       String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ===== SEO / BLOG PAGES =====
model SeoPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  h1              String?
  body            String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== OBSERVABILITY =====
model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  metadata   Json
  ipAddress  String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ===== SITE SETTINGS =====
model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String?  @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}
